{
  "name": "cypress-serverest-tests",
  "version": "1.0.0",
  "description": "Testes Cypress do ServeRest (e2e + api)",
  "private": true,
  "scripts": {
    "cy:open": "cypress open",
    "cypress:open": "cypress open",
    "test:frontend": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:e2e": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:all": "cypress run --spec \"cypress/e2e/**/*.cy.js\"",
    "lint": "eslint . --ext .js",
    "ci:test": "npm run lint && npm run test:all"
  },
  "keywords": ["cypress", "serverest", "e2e", "api-testing", "qa"],
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cypress": "^14.5.2",
    "cypress-mochawesome-reporter": "^3.8.2",
    "eslint": "^8.57.1",
    "eslint-plugin-cypress": "^3.6.0"
  }
}
